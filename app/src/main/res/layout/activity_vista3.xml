<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/alert_title"
            android:textSize="24sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/alert_subtitle" />

        <EditText
            android:id="@+id/editContacto1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/alert_hint_contact_1"
            android:inputType="phone" />

        <EditText
            android:id="@+id/editContacto2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/alert_hint_contact_2"
            android:inputType="phone" />

        <EditText
            android:id="@+id/editContacto3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/alert_hint_contact_3"
            android:inputType="phone" />

        <Button
            android:id="@+id/buttonEnviarAlerta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/alert_btn_send" />

        <Button
            android:id="@+id/buttonAlertaSilenciosa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/alert_btn_send_silent" />

        <TextView
            android:id="@+id/textEstadoAlerta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/alert_status_placeholder"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
