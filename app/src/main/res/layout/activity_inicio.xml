<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/textTituloInicio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/inicio_title"
            android:textSize="28sp" />

        <TextView
            android:id="@+id/textSubtituloInicio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/inicio_subtitle" />

        <Button
            android:id="@+id/buttonMapa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/inicio_btn_mapa" />

        <Button
            android:id="@+id/buttonModoCertero"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/inicio_btn_modo_certero" />

        <Button
            android:id="@+id/buttonAlertaCero"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/inicio_btn_alerta" />

        <TextView
            android:id="@+id/textEstadoInicio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/inicio_status_ready"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
